---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = "Automatizare AI: Suport Clienti, Lead-uri, Documente | Angajeaza un Robot",
  description = "Redu costurile cu agenti AI 24/7: suport WhatsApp, calificare lead-uri, contracte si oferte automate. Solutii Microsoft Copilot si Gemini in Romania.",
  canonical = "https://angajeazaunrobot.ro/"
} = Astro.props;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Angajeaza un Robot",
  url: "https://angajeazaunrobot.ro",
  description,
  email: "mirceaipopescu@gmail.com",
  telephone: "+40744681989",
  areaServed: {
    "@type": "Country",
    name: "Romania"
  },
  knowsAbout: [
    "Agentic AI",
    "Automatizare procese business",
    "Implementare Microsoft Copilot",
    "chatbot WhatsApp afaceri",
    "automatizare documente juridice",
    "precalificare lead-uri",
    "Google Gemini pentru companii",
    "AI pentru companii Romania"
  ],
  contactPoint: [
    {
      "@type": "ContactPoint",
      contactType: "sales",
      areaServed: "RO",
      availableLanguage: ["ro"],
      email: "mirceaipopescu@gmail.com",
      telephone: "+40744681989"
    },
    {
      "@type": "ContactPoint",
      contactType: "customer support",
      areaServed: "RO",
      availableLanguage: ["ro"],
      email: "salut@angajeazaunrobot.ro",
      telephone: "+40744681989"
    }
  ]
};

const servicesSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Solutii AI Angajeaza un Robot",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      item: {
        "@type": "Service",
        name: "Automatizare Suport Clienti WhatsApp",
        description: "Redu costurile cu un agent AI pe WhatsApp disponibil 24/7. Rezolva 80% din intrebarile repetitive instant si imbunatateste experienta clientilor tai.",
        provider: { "@type": "Organization", name: "Angajeaza un Robot", url: "https://angajeazaunrobot.ro" }
      }
    },
    {
      "@type": "ListItem",
      position: 2,
      item: {
        "@type": "Service",
        name: "Calificare Lead-uri AI si Vanzari Automate",
        description: "Nu mai pierde niciun lead. Agentul AI preia cererile din WhatsApp si Email, identifica bugetul si trimite datele direct in SharePoint.",
        provider: { "@type": "Organization", name: "Angajeaza un Robot", url: "https://angajeazaunrobot.ro" }
      }
    },
    {
      "@type": "ListItem",
      position: 3,
      item: {
        "@type": "Service",
        name: "Automatizare Documente si Operatiuni Interne",
        description: "Generare automata de contracte si facturi. Elimina munca manuala si erorile cu roboti care gestioneaza fluxul de semnaturi si arhivarea.",
        provider: { "@type": "Organization", name: "Angajeaza un Robot", url: "https://angajeazaunrobot.ro" }
      }
    },
    {
      "@type": "ListItem",
      position: 4,
      item: {
        "@type": "Service",
        name: "Marketing AI pentru Multinationale",
        description: "Automatizeaza crearea de produse si campanii adaptate local. Agentul AI analizeaza stocurile si trendurile pentru a genera oferte personalizate.",
        provider: { "@type": "Organization", name: "Angajeaza un Robot", url: "https://angajeazaunrobot.ro" }
      }
    },
    {
      "@type": "ListItem",
      position: 5,
      item: {
        "@type": "Service",
        name: "Generator Oferte din Imagini si Planuri",
        description: "Transforma schitele si listele de materiale in oferte profesionale in cateva minute. Fara introducere manuala de date, doar incarcare si procesare.",
        provider: { "@type": "Organization", name: "Angajeaza un Robot", url: "https://angajeazaunrobot.ro" }
      }
    },
    {
      "@type": "ListItem",
      position: 6,
      item: {
        "@type": "Service",
        name: "Documentatie Tehnica Multilingva",
        description: "Transforma specificatiile brute in manuale structurate si traduse automat. Economiseste timp si costuri cu traduceri tehnice precise prin AI.",
        provider: { "@type": "Organization", name: "Angajeaza un Robot", url: "https://angajeazaunrobot.ro" }
      }
    }
  ]
};
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:locale" content="ro_RO" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Angajeaza un Robot" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(servicesSchema)} />
  </head>
  <body>
    <slot />
  </body>
</html>
