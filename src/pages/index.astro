---
import Layout from "../layouts/Layout.astro";

interface ChatExample {
  client: string;
  robot: string;
}

interface UseCase {
  title: string;
  idealFor: string;
  tech: string;
  integration?: string;
  focus?: string;
  description: string;
  examples?: ChatExample[];
}

interface OnPremSolution {
  title: string;
  idealFor: string;
  tech: string;
  integration?: string;
  focus?: string;
  description: string;
  flow?: string[];
}

const title = "Automatizare AI: Suport Clienti, Lead-uri, Documente | Angajeaza un Robot";
const description = "Redu costurile cu agenti AI 24/7: suport WhatsApp, calificare lead-uri, contracte si oferte automate. Solutii Microsoft Copilot si Gemini in Romania.";
const canonical = "https://angajeazaunrobot.ro/";
const primaryEmail = "mirceaipopescu@gmail.com";
const secondaryEmail = "salut@angajeazaunrobot.ro";
const phone = "+40744681989";
const phoneDisplay = "+40 744 681 989";

const useCases: UseCase[] = [
  {
    title: "Automatizare Suport Clienti",
    idealFor: "Parcuri auto, inchirieri masini, Marketplace-uri",
    tech: "Microsoft Copilot, Google Gemini",
    integration: "WhatsApp",
    description: "Agentul AI rezolva automat pana la 80% din intrebarile repetitive — rezervari, retururi, informatii despre produse — direct pe WhatsApp, 24/7. Costuri operationale minime: Clientul primeste un raspuns in secunde, nu in ore. Cazurile complexe sunt escalate automat catre echipa umana, impreuna cu tot istoricul conversatiei.",
    examples: [
      {
        client: "Aveti disponibil un SUV pentru weekendul viitor in Bucuresti?",
        robot: "Buna! Verific imediat... Da, avem un Volvo XC60 disponibil. Pretul este de 80€/zi. Vreti sa il rezervam acum?"
      },
      {
        client: "Cum pot returna un produs cumparat ieri?",
        robot: "Sigur! Aveti nevoie de numarul comenzii. Va pot genera acum link-ul pentru curier daca imi confirmati adresa."
      }
    ]
  },
  {
    title: "Precalificare Lead-uri in Vanzari & Listari",
    idealFor: "Dezvoltatori software, Marketplace-uri",
    integration: "WhatsApp, Email, SharePoint, Telefon (Voce)",
    tech: "Microsoft Copilot, Google Gemini",
    description: "Niciun lead nu se mai pierde, iar costul de achizitie scade. Agentul preia cereri din WhatsApp, email sau telefon, identifica bugetul, urgenta si locatia si trimite automat o fisa completa direct in SharePoint. Rezultatul: O lista de clienti calificati, gata pentru vanzare, fara nicio secunda de munca manuala."
  },
  {
    title: "Automatizare Operatiuni Interne",
    idealFor: "Contabilitate, Avocatura, Notari, Servicii, Software Dev",
    integration: "SharePoint, Google Drive",
    tech: "Microsoft Copilot, Google Gemini",
    description: "Agentul genereaza contracte, facturi si documente tehnice dintr-un template in cateva secunde. Urmareste automat fluxul de aprobare si semnaturile digitale, apoi arhiveaza totul la final. Elimini erorile umane si costurile administrative inutile. Zero copy-paste, zero documente ratacite."
  }
];

const onPremSolutions: OnPremSolution[] = [
  {
    title: "Automatizare Departament de Marketing",
    idealFor: "Multinationale",
    focus: "Generare produse noi adaptate zonei de livrare",
    tech: "Microsoft Copilot",
    integration: "SharePoint, Email",
    description: "Agentul AI analizeaza trendurile locale si stocurile pentru fiecare regiune, generand automat descrieri de produse si strategii de pret personalizate. Eficienta scalabila: Tot continutul este livrat direct in SharePoint, gata de publicat."
  },
  {
    title: "Generator de Oferte din Documente si Imagini",
    idealFor: "Firme de constructii, instalatori, furnizori de materiale",
    tech: "Agent custom on-premises",
    description: "Transforma orice dosar de proiect (fotografii, planuri, devize) intr-o oferta profesionala in cateva minute. Costuri reduse de procesare: Fara introducere manuala de date.",
    flow: [
      "Incarci imaginile si listele de materiale in folderul dedicat.",
      "Agentul extrage automat cantitati, specificatii si preturi.",
      "Validezi datele extrase printr-o interfata simpla.",
      "Oferta finala este generata automat in formatul tau oficial."
    ]
  },
  {
    title: "Generator de Documentatie Tehnica Multilingva",
    idealFor: "Firme de constructii, producatori de echipamente",
    tech: "Agent custom on-premises",
    description: "Transforma schitele si manualele brute in documentatie structurata, disponibila instant in mai multe limbi. Economisesti costurile uriase cu traducerile manuale si asiguri acuratetea tehnica.",
    flow: [
      "Incarci specificatiile brute si schitele intr-un folder.",
      "Agentul structureaza informatia conform template-ului tau tehnic.",
      "Sistemul solicita completari operatorului uman daca exista neclaritati.",
      "Documentatia este livrata complet, tradusa si gata de distributie."
    ]
  }
];
---

<Layout {title} {description} {canonical}>
  <main>
    <section class="hero" aria-labelledby="titlu-principal">
      <div class="container">
        <p class="eyebrow">Agentic AI pentru companii din Romania</p>
        <h1 id="titlu-principal">Angajeaza un Robot si scaleaza fara sa maresti echipa</h1>
        <p class="lead">
          Construim sisteme AI orientate pe rezultate: agenti care vorbesc cu clientii,
          automatizeaza procese operationale si lucreaza 24/7, cu cost predictibil si control uman.
        </p>
        <div class="hero-cta">
          <a class="button primary" href={`tel:${phone}`}>Suna si Cere un Demo</a>
          <a class="button secondary" href="#contact">Discuta cu noi</a>
          <a class="button secondary" href="#use-case-uri">Vezi solutii</a>
        </div>
      </div>
    </section>

    <section id="use-case-uri" class="section" aria-labelledby="titlu-use-case">
      <div class="container">
        <h2 id="titlu-use-case">🤖 Automatizari AI — Solutii gata de implementat</h2>
        <p class="lead">Eficienta maxima cu investitii minime. Implementare rapida, costuri de mentenanta scazute si adoptie garantata prin training inclus.</p>
        <div class="grid use-cases-grid">
          {
            useCases.map((item) => (
              <article class="card">
                <h3>{item.title}</h3>
                <div class="use-case-meta">
                  <p><span class="k-label">Ideal pentru:</span> {item.idealFor}</p>
                  <p><span class="k-label">Tehnologie:</span> {item.tech}</p>
                  {item.integration && <p><span class="k-label">Integrare cu:</span> {item.integration}</p>}
                  {item.focus && <p><span class="k-label">Focus:</span> {item.focus}</p>}
                </div>
                <p class="use-case-desc">{item.description}</p>
                {item.examples && (
                  <button type="button" class="chat-trigger" id="open-chat-demo">
                    Vezi exemplu conversatie WhatsApp →
                  </button>
                )}
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <div class="modal-overlay" id="chat-modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">
      <div class="modal-box">
        <div class="modal-header">
          <p class="modal-title" id="modal-title">Exemplu conversatie — WhatsApp</p>
          <button type="button" class="modal-close" id="close-chat-modal" aria-label="Inchide">✕</button>
        </div>
        <div class="chat-exchange">
          <div class="chat-msg chat-client">
            <span class="chat-who">Client</span>
            Aveti disponibil un SUV pentru weekendul viitor in Bucuresti?
          </div>
          <div class="chat-msg chat-robot">
            <span class="chat-who">Robot AI</span>
            Buna! Verific imediat... Da, avem un Volvo XC60 disponibil. Pretul este de 80€/zi. Vreti sa il rezervam acum?
          </div>
          <div class="chat-msg chat-client">
            <span class="chat-who">Client</span>
            Cum pot returna un produs cumparat ieri?
          </div>
          <div class="chat-msg chat-robot">
            <span class="chat-who">Robot AI</span>
            Sigur! Aveti nevoie de numarul comenzii. Va pot genera acum link-ul pentru curier daca imi confirmati adresa.
          </div>
        </div>
      </div>
    </div>

    <section id="solutii-custom" class="section" aria-labelledby="titlu-on-prem">
      <div class="container">
        <p class="eyebrow eyebrow-teal">🔒 On-Premises &amp; Custom</p>
        <h2 id="titlu-on-prem">Automatizari AI — Solutii on prem/custom</h2>
        <p class="lead">
          <strong>Solutii de inalta securitate cu costuri trasabile si control total.</strong><br>
          Agenti AI construiti si rulati local, pe infrastructura ta. Datele nu parasesc niciodata reteaua companiei, oferind timpi de implementare si migrare flexibili.
        </p>
        <div class="grid on-prem-grid">
          {
            onPremSolutions.map((item) => (
              <article class="card card-onprem">
                <h3>{item.title}</h3>
                <div class="use-case-meta">
                  <p><span class="k-label">Ideal pentru:</span> {item.idealFor}</p>
                  <p><span class="k-label">Tehnologie:</span> {item.tech}</p>
                  {item.integration && <p><span class="k-label">Integrare cu:</span> {item.integration}</p>}
                  {item.focus && <p><span class="k-label">Focus:</span> {item.focus}</p>}
                </div>
                <p class="use-case-desc">{item.description}</p>
                {item.flow && (
                  <>
                    <p class="flow-heading">Cum functioneaza:</p>
                    <ol class="flow-list">
                      {item.flow.map((step) => (
                        <li>{step}</li>
                      ))}
                    </ol>
                  </>
                )}
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="contact" class="section" aria-labelledby="titlu-contact">
      <div class="container contact">
        <h2 id="titlu-contact">Contact direct</h2>
        <p class="lead">
          Fara formulare si fara frictiuni. Suna-ne sau scrie-ne direct pentru o discutie despre primul tau agent AI.
        </p>
        <ul class="contact-list">
          <li>
            Email principal:
            <a href={`mailto:${primaryEmail}`}>{primaryEmail}</a>
          </li>
          <li>
            Email business:
            <a href={`mailto:${secondaryEmail}`}>{secondaryEmail}</a>
          </li>
          <li>
            Telefon:
            <a href={`tel:${phone}`}>{phoneDisplay}</a>
          </li>
        </ul>
        <div class="contact-cta">
          <a class="button primary" href={`tel:${phone}`}>Suna si Cere un Demo</a>
          <a class="button secondary" href={`mailto:${primaryEmail}`}>Scrie-ne un email</a>
        </div>
        <p class="contact-note">Raspundem in aceeasi zi lucratoare.</p>
        <div class="copy-wrap">
          <button type="button" class="copy-btn" id="copy-email" data-email={primaryEmail}>Copiaza email principal</button>
          <span class="copy-status" id="copy-status" role="status" aria-live="polite"></span>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      <small>Angajeaza un Robot - Agentie AI in Romania</small>
    </div>
  </footer>

  <script is:inline>
    // Copy email
    const copyButton = document.querySelector("#copy-email");
    const status = document.querySelector("#copy-status");

    if (copyButton && status) {
      copyButton.addEventListener("click", async () => {
        const email = copyButton.getAttribute("data-email") || "";
        try {
          await navigator.clipboard.writeText(email);
          status.textContent = "Copiat!";
          copyButton.textContent = "Copiat!";
        } catch {
          // Fallback pentru browsere mai restrictive.
          const tempInput = document.createElement("input");
          tempInput.value = email;
          document.body.appendChild(tempInput);
          tempInput.select();
          document.execCommand("copy");
          document.body.removeChild(tempInput);
          status.textContent = "Copiat!";
          copyButton.textContent = "Copiat!";
        }
        window.setTimeout(() => {
          status.textContent = "";
          copyButton.textContent = "Copiaza email principal";
        }, 1800);
      });
    }

    // Chat demo modal
    const openBtn = document.querySelector("#open-chat-demo");
    const closeBtn = document.querySelector("#close-chat-modal");
    const modal = document.querySelector("#chat-modal");

    if (openBtn && closeBtn && modal) {
      openBtn.addEventListener("click", () => {
        modal.classList.add("is-open");
        closeBtn.focus();
      });
      closeBtn.addEventListener("click", () => {
        modal.classList.remove("is-open");
      });
      modal.addEventListener("click", (e) => {
        if (e.target === modal) modal.classList.remove("is-open");
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && modal.classList.contains("is-open")) {
          modal.classList.remove("is-open");
        }
      });
    }
  </script>
</Layout>
